// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Cliente {
  id_cliente Int      @id @default(autoincrement())
  cedula_rif String   @unique @db.VarChar(20)
  nombre     String?  @db.VarChar(75)
  apellido   String?  @db.VarChar(75)
  telefono   String?  @db.VarChar(20)
  direccion  String?  @db.Text
  correo     String?  @db.VarChar(100)
  carros     Carro[]

  @@map("clientes")
}

model Carro {
  placa            String          @id @db.VarChar(15)
  id_cliente       Int
  marca            String?         @db.VarChar(50)
  modelo           String?         @db.VarChar(50)
  ano              Int?
  kilometraje      Int?
  categoria        String?         @db.VarChar(30) // Retained for backwards compatibility
  capacidad_tanque String?         @db.VarChar(20) // New
  cliente          Cliente         @relation(fields: [id_cliente], references: [id_cliente], onDelete: Cascade)
  ordenes          OrdenServicio[]

  @@map("carros")
}

model OrdenServicio {
  id_orden                Int                    @id @default(autoincrement())
  placa_carro             String                 @db.VarChar(15)
  id_mecanico             String?                @db.VarChar(20)
  fecha_ingreso           DateTime               @default(now())
  hora_ingreso            String?                @db.VarChar(10)
  estado                  String                 @default("Activa") @db.VarChar(30)
  motivo_visita           String?                @db.Text
  falla_declarada         String?                @db.Text
  tiene_caucho            Boolean                @default(false)
  tiene_radio             Boolean                @default(false)
  tiene_rayones           Boolean                @default(false)
  diagnostico_inicial     String?                @db.Text // Retained for backwards compatibility
  diagnostico_tecnico     String?                @db.Text
  observaciones           String?                @db.Text
  prioridad               String?                @default("normal") @db.VarChar(20) // Retained
  fecha_creacion          DateTime?              @default(now()) @db.Timestamp(6) // Retained
  carro                   Carro                  @relation(fields: [placa_carro], references: [placa], onDelete: Cascade)
  mecanico                Empleado?              @relation(fields: [id_mecanico], references: [id_empleado])
  detalles_repuestos      DetalleOrdenRepuesto[]
  detalles_servicios      DetalleOrdenServicio[]
  factura                 Factura?

  @@map("ordenes_servicio")
}

model DetalleOrdenServicio {
  id_orden             Int
  id_servicio          Int
  precio_aplicado      Decimal?       @db.Decimal(12, 2)
  es_especial          Boolean?       @default(false)
  descripcion_especial String?        @db.VarChar(200)
  orden                OrdenServicio  @relation(fields: [id_orden], references: [id_orden], onDelete: Cascade)
  servicio             Servicio       @relation(fields: [id_servicio], references: [id_servicio])

  @@id([id_orden, id_servicio])
  @@map("detalle_orden_servicios")
}

model Servicio {
  id_servicio             Int                    @id @default(autoincrement())
  nombre_servicio         String                 @db.VarChar(100)
  tipo_servicio           String?                @db.VarChar(50)
  precio_base             Decimal                @db.Decimal(12, 2)
  detalle_orden_servicios DetalleOrdenServicio[]

  @@map("servicios")
}

model Empleado {
  id_empleado         String          @id @db.VarChar(20)
  nombre              String?         @db.VarChar(75)
  apellido            String?         @db.VarChar(75)
  cargo               String?         @db.VarChar(50)
  telefono            String?         @db.VarChar(20) // Retained
  direccion           String?         // Retained
  sueldo_base         Decimal?        @db.Decimal(12, 2) // Retained
  aplica_comision     Boolean?        @default(false) // Retained
  monto_comision_fija Decimal?        @db.Decimal(12, 2) // Retained
  ordenes             OrdenServicio[]
  nominas             Nomina[]

  @@map("empleados")
}

model Inventario {
  id_repuesto               Int                    @id @default(autoincrement())
  codigo_barra              String?                @unique @db.VarChar(50) // Retained
  descripcion               String?                @db.VarChar(200)
  stock_actual              Int                    @default(0)
  precio_venta_sugerido     Decimal?               @db.Decimal(12, 2) // Retained
  precio_compra             Decimal?               @db.Decimal(12, 2)
  detalles                  DetalleOrdenRepuesto[]
  detalle_compras           DetalleCompra[]
  detalle_factura_repuestos DetalleFacturaRepuesto[]

  @@map("inventario")
}

model DetalleOrdenRepuesto {
  id_detalle_repuesto Int            @id @default(autoincrement())
  id_orden            Int
  id_repuesto         Int
  cantidad            Int
  orden               OrdenServicio  @relation(fields: [id_orden], references: [id_orden], onDelete: Cascade)
  repuesto            Inventario     @relation(fields: [id_repuesto], references: [id_repuesto])

  @@map("detalle_orden_repuestos")
}

model Factura {
  id_factura                Int           @id @default(autoincrement())
  id_orden                  Int           @unique
  monto_total               Decimal       @db.Decimal(12, 2)
  subtotal                  Decimal?      @db.Decimal(12, 2) // Retained
  monto_iva                 Decimal?      @db.Decimal(12, 2) // Retained
  monto_igtf                Decimal?      @db.Decimal(12, 2) // Retained
  tasa_cambio               Decimal?      @db.Decimal(12, 4) // Retained
  metodo_pago               String?       @db.VarChar(50) // Retained
  fecha_emision             DateTime?     @default(now()) @db.Timestamp(6) // Retained
  orden                     OrdenServicio @relation(fields: [id_orden], references: [id_orden])
  detalle_factura_repuestos DetalleFacturaRepuesto[]

  @@map("facturas")
}

model Usuario {
  id_usuario Int     @default(autoincrement())
  correo     String  @unique @db.VarChar(100)
  contrasena String  @db.VarChar(255)
  rol        String  @default("user") @db.VarChar(20)
  cedula_rif String  @id @db.VarChar(20)
  nombre     String? @db.VarChar(75)
  apellido   String? @db.VarChar(75)
  
  gastos     Gasto[]
  compras    Compra[]

  @@map("usuarios")
}

// RESTORED TABLES:

model Compra {
  id_compra              Int             @id @default(autoincrement())
  id_proveedor           Int?
  registrado_por_usuario String?         @db.VarChar(20)
  descripcion            String?         @db.VarChar(100)
  monto_total            Decimal?        @db.Decimal(12, 2)
  fecha                  DateTime?       @default(now()) @db.Timestamp(6)
  estado                 String?         @default("POR PAGAR") @db.VarChar(20)

  usuario                Usuario?        @relation(fields: [registrado_por_usuario], references: [cedula_rif])
  proveedor              Proveedor?      @relation(fields: [id_proveedor], references: [id_proveedor])
  detalle_compras        DetalleCompra[]

  @@map("compras")
}

model DetalleCompra {
  id_detalle_compra      Int         @id @default(autoincrement())
  id_compra              Int?
  id_repuesto            Int?
  cantidad               Int
  precio_compra_unitario Decimal     @db.Decimal(12, 2)
  compra                 Compra?     @relation(fields: [id_compra], references: [id_compra], onDelete: Cascade, onUpdate: NoAction)
  repuesto               Inventario? @relation(fields: [id_repuesto], references: [id_repuesto], onDelete: NoAction, onUpdate: NoAction)

  @@map("detalle_compras")
}

model DetalleFacturaRepuesto {
  id_detalle_venta      Int         @id @default(autoincrement())
  id_factura            Int?
  id_repuesto           Int?
  cantidad              Int
  precio_venta_unitario Decimal     @db.Decimal(12, 2)
  factura               Factura?    @relation(fields: [id_factura], references: [id_factura], onDelete: Cascade, onUpdate: NoAction)
  repuesto              Inventario? @relation(fields: [id_repuesto], references: [id_repuesto], onDelete: NoAction, onUpdate: NoAction)

  @@map("detalle_factura_repuestos")
}

model Gasto {
  id_gasto               Int       @id @default(autoincrement())
  id_proveedor           Int?      
  registrado_por_usuario String?   @db.VarChar(20)
  descripcion            String?   @db.VarChar(100)
  monto                  Decimal?  @db.Decimal(12, 2)
  categoria              String?   @db.VarChar(50) // "alquiler", "servicios_basicos", "herramientas", "otros"
  fecha                  DateTime? @default(now()) @db.Timestamp(6)
  estado                 String?   @default("POR PAGAR") @db.VarChar(20)

  usuario                Usuario?    @relation(fields: [registrado_por_usuario], references: [cedula_rif])
  proveedor              Proveedor?  @relation(fields: [id_proveedor], references: [id_proveedor])

  @@map("gastos")
}

model Nomina {
  id_pago        Int       @id @default(autoincrement())
  id_empleado    String?   @db.VarChar(20)
  monto_comision Decimal?  @db.Decimal(12, 2)
  monto_sueldo   Decimal?  @db.Decimal(12, 2)
  monto_total    Decimal?  @db.Decimal(12, 2)
  periodo        String?   @db.VarChar(20)
  tipo_pago      String?   @db.VarChar(20) // "comision", "quincenal", "liquidacion"
  fecha_pago     DateTime? @default(now()) @db.Timestamp(6)
  empleado       Empleado? @relation(fields: [id_empleado], references: [id_empleado], onDelete: NoAction, onUpdate: NoAction)

  @@map("nomina")
}

model Proveedor {
  id_proveedor      Int       @id @default(autoincrement())
  id_persona        Int?
  rif               String    @db.VarChar(20)
  nombre_empresa    String?   @db.VarChar(100)
  especialidad      String?   @db.VarChar(100)
  nombre_contacto   String?   @db.VarChar(75)
  apellido_contacto String?   @db.VarChar(75)
  
  compras           Compra[]
  gastos            Gasto[]

  @@map("proveedores")
}